  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Divyansh\",\n  \"email\": \"abc@gmail.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"abc@gmail.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Upload ZIP Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/projects/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "projects",
                "upload"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Import GitHub Repo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"repoUrl\": \"https://github.com/user/project\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/github",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "projects",
                "github"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get User Projects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "projects"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Start Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectId\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/review/start",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "review",
                "start"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Review Result",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/review/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "review",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "456",
                  "description": "Review ID"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI Chat",
      "item": [
        {
          "name": "Ask AI",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewId\": \"123\",\n  \"message\": \"Explain this function\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "chat"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Download PDF Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/report/:reviewId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "report",
                ":reviewId"
              ],
              "variable": [
                {
                  "key": "reviewId",
                  "value": "123",
                  "description": "Review ID"
                }
              ]
            }
          },
          "response": []
        }
      ]
